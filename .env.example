# Generic provider configuration.
# Use this for OpenAI-compatible gateways, MiniMax-compatible endpoints,
# enterprise gateways, or any provider supported by src/llm.py.
LLM_LABEL=Custom OpenAI-compatible
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# OpenAI shortcut. Shown in the UI only when OPENAI_API_KEY is set.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic shortcut. Shown in the UI only when ANTHROPIC_API_KEY is set.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
